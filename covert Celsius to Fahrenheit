def convert_to_fahrenheit(c):
    return (c * 9/5) + 32
#get the input from user
c = float(input("Enter the Temperature Value in Celsius: "))
#calling the function
f = convert_to_fahrenheit(c)
#print the result
print(f"Result: {c}°C = {f:.2f}°F")
